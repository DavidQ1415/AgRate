{
  "manifest_version": 3,
  "name": "AgRate: Schedule Builder Ratings",
  "version": "1.0.0",
  "description": "Shows RateMyProfessors ratings and ANEX GPA data inside the Texas A&M Schedule Builder. Made by David Quiroz Sanchez.",
  "author": "David Quiroz Sanchez",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://www.ratemyprofessors.com/*",
    "https://anex.us/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://tamu.collegescheduler.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
